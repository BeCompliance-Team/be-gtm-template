___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const setDefaultConsentState = require('setDefaultConsentState');
const injectScript = require('injectScript');
const queryPermission = require('queryPermission');
const logToConsole = require('logToConsole');

const clientId = data.clientId;

if (!clientId) {
  logToConsole('Be.Aliant CMP: Erro - Client ID não informado.');
  data.gtmOnFailure();
  return;
}

if (data.enableConsentMode !== false) {
  const defaultSettings = data.defaultSettings;

  if (defaultSettings && defaultSettings.length > 0) {
    defaultSettings.forEach(row => {
      const consentObj = {
        'ad_storage': row.ad_storage || 'denied',
        'analytics_storage': row.analytics_storage || 'denied',
        'ad_user_data': row.ad_user_data || 'denied',
        'ad_personalization': row.ad_personalization || 'denied',
        'functionality_storage': 'denied',
        'personalization_storage': 'denied',
        'security_storage': 'granted',
        'wait_for_update': 500
      };

      if (row.region && row.region.trim() !== '') {
        const regions = row.region.split(',').map(r => r.trim());
        if (regions.length > 0) {
          consentObj.region = regions;
        }
      }

      setDefaultConsentState(consentObj);
    });
  } else {
    // Fallback de segurança caso a tabela esteja vazia
    setDefaultConsentState({
      'ad_storage': 'denied',
      'analytics_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'functionality_storage': 'denied',
      'personalization_storage': 'denied',
      'security_storage': 'granted',
      'wait_for_update': 500
    });
  }
}

const cmpUrl = 'https://cdn-api-cmp.becompliance.com/client-side/' + clientId + '.js';

if (queryPermission('inject_script', cmpUrl)) {
  injectScript(cmpUrl, () => {
    logToConsole('Be.Aliant CMP: Script carregado com sucesso.');
    data.gtmOnSuccess();
  }, () => {
    logToConsole('Be.Aliant CMP: Falha ao carregar o script.');
    data.gtmOnFailure();
  }, 'becompliance-cmp-script');
} else {
  logToConsole('Be.Aliant CMP: Permissão de injeção de script negada pelo GTM.');
  data.gtmOnFailure();
}


